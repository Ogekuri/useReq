{
  "guidelines-dir": "guidelines",
  "docs-dir": "docs",
  "tests-dir": "tests",
  "src-dir": [
    "src",
    "scripts",
    ".github/workflows"
  ],
  "static-check": {
    "C": [
      {
        "module": "Command",
        "cmd": "cppcheck",
        "params": [
          "--error-exitcode=1",
          "--enable=warning,style,performance,portability",
          "--std=c11"
        ]
      },
      {
        "module": "Command",
        "cmd": "clang-format",
        "params": [
          "--dry-run",
          "--Werror"
        ]
      }
    ],
    "C++": [
      {
        "module": "Command",
        "cmd": "cppcheck",
        "params": [
          "--error-exitcode=1",
          "--enable=warning,style,performance,portability",
          "--std=c++20"
        ]
      },
      {
        "module": "Command",
        "cmd": "clang-format",
        "params": [
          "--dry-run",
          "--Werror"
        ]
      }
    ],
    "Python": [
      {
        "module": "Pylance"
      },
      {
        "module": "Ruff"
      }
    ],
    "JavaScript": [
      {
        "module": "Command",
        "cmd": "node",
        "params": [
          "--check"
        ]
      }
    ]
  },
  "enable-models": false,
  "enable-tools": false,
  "enable-claude": true,
  "enable-codex": true,
  "enable-gemini": true,
  "enable-github": true,
  "enable-kiro": true,
  "enable-opencode": true,
  "install-prompts": true,
  "install-agents": false,
  "install-skills": false,
  "prompts-use-agents": false,
  "legacy": false,
  "preserve-models": false
}